  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(process_memory_rss_bytes{name=\"observer\"}, ob_cluster_name)",
        "query": "label_values(process_memory_rss_bytes{name=\"observer\"}, ob_cluster_name)",
        "refresh": 1,
        "sort": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "",
          "value": ""
        },
        "options": [],
        "skipUrlSync": false
      },
      {
        "name": "zone",
        "label": "Zone",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(process_memory_rss_bytes{name=\"observer\",ob_cluster_name=\"$cluster\"}, obzone)",
        "query": "label_values(process_memory_rss_bytes{name=\"observer\",ob_cluster_name=\"$cluster\"}, obzone)",
