      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "sum(process_memory_rss_bytes{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip)",
          "legendFormat": "RSS Memory - {{svr_ip}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "avg(process_cpu_percent{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip)",
          "legendFormat": "CPU Percent - {{svr_ip}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "avg(process_fd_count{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip)",
          "legendFormat": "FD Count - {{svr_ip}}",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "avg(process_thread_count{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip)",
          "legendFormat": "Thread Count - {{svr_ip}}",
          "refId": "D"
        }
      ]
    },
