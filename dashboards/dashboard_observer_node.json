        "options": [],
        "skipUrlSync": false
      },
      {
        "name": "svr_ip",
        "label": "Server IP",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(process_memory_rss_bytes{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\"}, svr_ip)",
        "query": "label_values(process_memory_rss_bytes{name=\"observer\",ob_cluster_name=\"$cluster\",obzone=~\"$zone\"}, svr_ip)",
        "refresh": 1,
        "sort": 1,
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [],
        "skipUrlSync": false
      },
      {
        "name": "interval",
        "label": "Interval",
        "type": "interval",
        "hide": 0,
        "query": "30s,1m,5m",
        "auto": false,
        "auto_count": 30,
        "auto_min": "10s",
        "current": {
          "selected": true,
          "text": "1m",
          "value": "1m"
        },
        "options": [],
        "skipUrlSync": false
      }
