        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "sum(node_load1{ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip) / sum(cpu_count{ob_cluster_name=\"$cluster\",obzone=~\"$zone\",svr_ip=~\"$svr_ip\"}) by (svr_ip)",
